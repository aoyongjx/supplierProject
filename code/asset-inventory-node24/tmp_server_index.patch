+function isTransientDbConnectionError(error) {
+  const message = String(error?.message || '').toLowerCase()
+  const code = String(error?.code || '').toUpperCase()
+  if (code === 'ETIMEDOUT' || code === 'ECONNRESET' || code === 'ECONNREFUSED') return true
+  return (
+    message.includes('connection terminated due to connection timeout')
+    || message.includes('terminating connection due to idle-in-transaction timeout')
+    || message.includes('timeout expired')
+    || message.includes('connection timeout')
+    || message.includes('connect etimedout')
+    || message.includes('socket hang up')
+  )
+}
+
+async function queryWithDbRetry(sql, params = [], { retryOnce = true, reason = 'query' } = {}) {
+  try {
+    return await pool.query(sql, params)
+  } catch (error) {
+    if (!retryOnce || !isTransientDbConnectionError(error)) throw error
+    dbReady = false
+    dbInitErrorMessage = error.message || 'db_transient_error'
+    await tryInitializeDatabaseIfNeeded(`retry:${reason}`)
+    return pool.query(sql, params)
+  }
+}
+
+pool.on('error', (error) => {
+  if (isTransientDbConnectionError(error)) {
+    dbReady = false
+    dbInitErrorMessage = error.message || 'db_pool_error'
+  }
+  console.warn(`[db-pool] ${error?.message || 'unknown pool error'}`)
+})
