        function pySort(arr) {
            if (!String.prototype.localeCompare) return null
            let letters = 'ABCDEFGHJKLMNOPQRSTWXYZ'.split('')
            //let zh = '阿八嚓哒妸发旮哈讥咔垃痳拏噢妑七呥扨它穵夕丫帀'.split('')
            let segs = []
            letters.forEach(function (item, i) {
                let cur = { letter: item, data: [] }
                arr.forEach(function (item) {
                    //var list = pinyinUtil.getFirstLetter(item.ManufacturerShortName, true);
                    //if (list.length > 0) {
                    //    if (list[list.length - 1].split('')[0] === letters[i]) {
                    //        cur.data.push(item)
                    //    }
                    //}

                    var list = pinyinUtil.getFirstLetter(item.ManufacturerShortName, true);
                    if (list.length > 0) {
                        var info;
                        if (item.ManufacturerShortName.substr(0, 1) === "长"
                            || item.ManufacturerShortName.substr(0, 2) === "蔚来") {
                            info = list[list.length - 1];
                        } else {
                            info = list[0];
                        }

                        if (info.split('')[0] === letters[i]) {
                            cur.data.push(item)
                        }
                    }


                    //if (pinyinUtil.getFirstLetter(item.ManufacturerShortName).split('')[0] === letters[i]) {
                    //    cur.data.push(item)
                    //}

                    //if (item.ManufacturerShortName.localeCompare(zh[i]) >= 0 && item.ManufacturerShortName.localeCompare(zh[i + 1]) < 0) {
                    //    cur.data.push(item)
                    //}
                })
                if (cur.data.length) {
                    cur.data.sort(function (a, b) {
                        return a.ManufacturerShortName.localeCompare(b, 'zh')
                    })
                    segs.push(cur)
                }
            })
            return segs
        }

