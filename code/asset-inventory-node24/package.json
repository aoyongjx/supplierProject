{
  "name": "asset-inventory-node24",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "stable": "concurrently \"npm:stable:server\" \"npm:stable:client\"",
    "stable:client": "vite preview --host 127.0.0.1 --strictPort --port 5173",
    "stable:server": "node server/index.js",
    "start": "node server/index.js",
    "build": "vite build",
    "verify:stocks": "node scripts/verify-stocks.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "antd": "^6.3.6",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lightweight-charts": "^5.1.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "plotly.js-dist-min": "^3.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph": "^1.48.2",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0",
    "umap-js": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  }
}
